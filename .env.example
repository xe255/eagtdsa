# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Single admin:
ADMIN_CHAT_ID=your_admin_chat_id_here
# Or multiple admins (comma-separated). If set, overrides ADMIN_CHAT_ID.
# ADMIN_CHAT_IDS=123,456,789

# Required group - MANDATORY for production! Users must join to use the bot.
# 1. Add the bot to your Telegram group
# 2. In the group, run /getgroupid (as admin) to get the ID
# 3. Set REQUIRED_GROUP_ID below AND in Zeabur Environment Variables!
REQUIRED_GROUP_ID=-5222995089
REQUIRED_GROUP_INVITE=https://t.me/+F7ywFh8iVpVjODBk

# One-shot export of ALL group members into db.json (user session — NOT the bot token)
# Get api_id / api_hash at https://my.telegram.org — devDependency: telegram (GramJS)
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=...
# TELEGRAM_USER_SESSION=   # paste after first login; keep secret

# Server Configuration
PORT=3000

# Persistent database path (IMPORTANT for Zeabur!)
# Set this to the mount path of your Zeabur volume, e.g. /data/db.json
# Without this, db.json is wiped on every redeploy.
# DB_PATH=/data/db.json

# Application Settings
MAX_ACCOUNTS_PER_USER=3
TRIAL_DURATION_DAYS=3
