# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Single admin:
ADMIN_CHAT_ID=your_admin_chat_id_here
# Or multiple admins (comma-separated). If set, overrides ADMIN_CHAT_ID.
# ADMIN_CHAT_IDS=123,456,789

# Required group - MANDATORY for production! Users must join to use the bot.
# 1. Add the bot to your Telegram group
# 2. In the group, run /getgroupid (as admin) to get the ID
# 3. Set REQUIRED_GROUP_ID below AND in Zeabur Environment Variables!
REQUIRED_GROUP_ID=-5222995089
REQUIRED_GROUP_INVITE=https://t.me/+F7ywFh8iVpVjODBk

# One-shot export of ALL group members into db.json (user session — NOT the bot token)
# Get api_id / api_hash at https://my.telegram.org — devDependency: telegram (GramJS)
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=...
# TELEGRAM_USER_SESSION=   # paste after first login; keep secret

# Server Configuration
PORT=3000

# Public base URL (no trailing slash) — broadcast tracking links + optional keep-alive self-ping
# Render production example (no trailing slash):
# PUBLIC_URL=https://embyil-generator.onrender.com

# Render free tier: inbound GET /health every 10 min so the service stays warm
# KEEP_ALIVE_SELF_PING=true
# KEEP_ALIVE_INTERVAL_MS=600000

# Persistent database path (IMPORTANT for Zeabur / any volume mount)
# DB_PATH=/data/db.json

# --- Render free tier (no disk): remote JSON backup via Upstash Redis (free) ---
# Create a Redis database at https://upstash.com → copy REST URL + token.
# The full db (logs, chats, groupMembers for broadcasts, etc.) is stored in one key.
# Debounced writes (~2s) + flush on SIGTERM. Set on Render as env vars (no card on free signup at time of writing).
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Optional key name (default embyil-db):
# UPSTASH_REDIS_DB_KEY=embyil-db

# --- Supabase (telegram_users cloud table for group/broadcast roster) ---
# Create table: run supabase/migrations/001_telegram_users.sql in the SQL Editor.
# On Render use SUPABASE_SERVICE_ROLE_KEY (Dashboard → Settings → API) — never expose in the browser.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # recommended for bot
# Or legacy / client keys (may require RLS policies for writes):
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...
# Backfill from local exports: npm run backfill:supabase

# Application Settings
MAX_ACCOUNTS_PER_USER=3
TRIAL_DURATION_DAYS=3
