# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Single admin:
ADMIN_CHAT_ID=your_admin_chat_id_here
# Or multiple admins (comma-separated). If set, overrides ADMIN_CHAT_ID.
# ADMIN_CHAT_IDS=123,456,789

# Required group - MANDATORY for production! Users must join to use the bot.
# 1. Add the bot to your Telegram group
# 2. In the group, run /getgroupid (as admin) to get the ID
# 3. Set REQUIRED_GROUP_ID below AND in Zeabur Environment Variables!
# Full supergroup id must look like -100xxxxxxxxxx (not the short -522… style from some tools).
REQUIRED_GROUP_ID=-5222995089
# Optional: for npm run scrape:group-once — @username or t.me link if -100 id fails in GramJS
# TELEGRAM_SEED_GROUP=@YourPublicGroup
# Used by the bot (join message) and by npm run scrape:group-once (GramJS auto-join).
REQUIRED_GROUP_INVITE=https://t.me/+F7ywFh8iVpVjODBk

# One-shot export of ALL group members into db.json + Supabase (user session — NOT the bot token)
# Get api_id / api_hash at https://my.telegram.org — devDependency: telegram (GramJS)
# Then: npm run scrape:group-once   (same as seed:group-members)
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=...
# TELEGRAM_USER_SESSION=   # paste after first login; keep secret

# Server Configuration
PORT=3000

# Emby signup API — canonical browser origin (Host/Origin/Referer). Default public site:
# EMBY_API_ORIGIN=https://emby.embyiltv.io
#
# Where Node actually connects (must end with /api, no trailing slash after api):
# Default: {EMBY_API_ORIGIN}/api
#
# FREE bypass when Cloudflare blocks Render: run scripts/emby-api-relay.js at HOME (or Oracle Free VM),
# expose with Cloudflare Quick Tunnel:  npx cloudflared tunnel --url http://127.0.0.1:8787
# Then set EMBY_API_FETCH_BASE to https://YOUR.trycloudflare.com/api and keep EMBY_API_ORIGIN as real site.
# Optional shared secret (set same on relay + bot):
# EMBY_RELAY_SECRET=long-random-string
#
# Proxy for Emby API (bypass IP blocks). Use the scheme your provider gives you:
# HTTP proxy:
# EMBY_HTTPS_PROXY=http://user:pass@host:port
# SOCKS5 (common for residential — do NOT use http:// here or undici will throw HTTPParserError):
# EMBY_HTTPS_PROXY=socks5://user:pass@host:port
# Or: EMBY_SOCKS_PROXY=socks5://user:pass@host:port
#
# --- Free HTTP proxy pool (lab / best-effort only) ---
# When EMBY_HTTPS_PROXY / EMBY_SOCKS_PROXY / HTTPS_PROXY are NOT set, you can enable a rotating pool
# built from a public GitHub list + proxycheck.io + live GET probes to the Emby site origin (EMBY_API_ORIGIN).
# WARNING: free proxies can inspect or steal traffic (including signup credentials). Prefer a trusted
# static proxy above. Respect proxycheck.io query limits; keep FREE_PROXY_MAX_CANDIDATES modest on Zeabur.
# FREE_PROXY_POOL=1
# PROXYCHECK_API_KEY=your_key_here   # optional — without it, reputation filter is skipped (all candidates probed)
# FREE_PROXY_LIST_URL can be comma-separated URLs to merge lists (when unset, uses built-in HTTP+HTTPS proxifly lists)
# FREE_PROXY_LIST_URL=https://raw.githubusercontent.com/proxifly/free-proxy-list/main/proxies/protocols/http/data.txt,https://raw.githubusercontent.com/proxifly/free-proxy-list/main/proxies/protocols/https/data.txt
# When primary comma-list URLs yield zero proxy lines, fetch TheSpeedX http.txt by default (host:port → http://).
# Override URL or disable: FREE_PROXY_FALLBACK_LIST_URL=https://...  |  FREE_PROXY_FALLBACK_LIST_URL=0
# FREE_PROXY_REFRESH_MS=3600000   # default 1h — list + ProxyCheck + probes run on this timer, with faster retries when empty
# FREE_PROXY_MAX_CANDIDATES=200
# FREE_PROXY_PROXYCHECK_CHUNK=80
# FREE_PROXY_MAX_RISK=90
# FREE_PROXY_PROBE_CONCURRENCY=4
# FREE_PROXY_PROBE_TIMEOUT_MS=5000
# FREE_PROXY_POOL_MAX=35
# FREE_PROXY_FALLBACK_DIRECT=1   # opt-in: hit Emby origin directly when the pool has no working proxy (often Cloudflare-blocked from the host)
# FREE_PROXY_EMPTY_RETRY_MS=120000   # when gate is on and pool empty after a refresh, schedule another refresh after this delay
# FREE_PROXY_SIGNUP_WITHOUT_POOL=1   # emergency: allow bot signup before pool is ready (not recommended)

# Telegram 409 "terminated by other getUpdates": only ONE process may poll this bot token.
# Stop local `node start.js`, duplicate Render services, or a second Zeabur deployment using the same TELEGRAM_BOT_TOKEN.

# Public base URL (no trailing slash) — broadcast tracking links + keep-alive self-ping
# On Render you can omit this: RENDER_EXTERNAL_URL is used automatically when PUBLIC_URL is unset.
# Custom domain or non-Render hosts:
# PUBLIC_URL=https://embyil-generator.onrender.com
#
# With PUBLIC_URL set, self-ping defaults ON: the app requests GET /health every 5 minutes so Render
# sees inbound traffic and is less likely to spin down (free tier ~15m idle). Set KEEP_ALIVE_SELF_PING=false to disable.
# For guaranteed 24/7 with no cold starts, upgrade the host (e.g. Render paid) or add an external uptime monitor.
# KEEP_ALIVE_SELF_PING=false
# KEEP_ALIVE_INTERVAL_MS=300000

# Persistent database path (IMPORTANT for Zeabur / any volume mount)
# DB_PATH=/data/db.json
# On Windows, leave DB_PATH unset for local dev — /data/db.json from Render is auto-ignored (uses ./db.json).

# --- Render free tier (no disk): remote JSON backup via Upstash Redis (free) ---
# Create a Redis database at https://upstash.com → copy REST URL + token.
# The full db (logs, chats, groupMembers for broadcasts, etc.) is stored in one key.
# Debounced writes (~2s) + flush on SIGTERM. Set on Render as env vars (no card on free signup at time of writing).
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Optional key name (default embyil-db):
# UPSTASH_REDIS_DB_KEY=embyil-db

# --- Supabase (telegram_users cloud table for group/broadcast roster) ---
# Create table: run supabase/migrations/001_telegram_users.sql in the SQL Editor.
# On Render use SUPABASE_SERVICE_ROLE_KEY (Dashboard → Settings → API) — never expose in the browser.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # recommended for bot
# Or legacy / client keys (may require RLS policies for writes):
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...
# Backfill from local exports: npm run backfill:supabase
# Bot: re-merge missing telegram_users into live groupMembers (Upstash) every N ms (default 1h). 0 = off.
# SUPABASE_MERGE_INTERVAL_MS=3600000

# Application Settings
MAX_ACCOUNTS_PER_USER=3
TRIAL_DURATION_DAYS=3
